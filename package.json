{
  "name": "@rohal12/twee-ts",
  "version": "0.1.0",
  "description": "TypeScript Twee-to-HTML compiler — a complete reimplementation of Tweego",
  "type": "module",
  "license": "Unlicense",
  "author": "Rohal12",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohal12/twee-ts.git"
  },
  "homepage": "https://github.com/rohal12/twee-ts",
  "bugs": "https://github.com/rohal12/twee-ts/issues",
  "keywords": [
    "twine",
    "twee",
    "tweego",
    "sugarcube",
    "harlowe",
    "interactive-fiction",
    "story-format",
    "compiler"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.js"
    },
    "./rollup": {
      "types": "./dist/plugins/rollup.d.ts",
      "import": "./dist/plugins/rollup.js"
    }
  },
  "bin": {
    "twee-ts": "./dist/bin/twee-ts.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck && pnpm test && pnpm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0-beta",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  }
}
